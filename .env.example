# ─────────────────────────────────────────────
# NGN Fishing — Environment Variables
# Copy to .env.local and fill in values.
# NEVER commit .env.local to git.
# All EXPO_PUBLIC_ vars are bundled into the app.
# ─────────────────────────────────────────────

# Anthropic Claude API
# Get from: console.anthropic.com
EXPO_PUBLIC_ANTHROPIC_API_KEY=sk-ant-REPLACE_ME

# OpenWeather
# Get from: openweathermap.org/api
EXPO_PUBLIC_OPENWEATHER_API_KEY=REPLACE_ME

# Supabase — shared with BuilderDeck/BuilderCheck
# Get from: supabase.com/dashboard
EXPO_PUBLIC_SUPABASE_URL=https://REPLACE_ME.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=REPLACE_ME

# Stripe — NGN Fishing subscriptions
# Get from: dashboard.stripe.com
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_REPLACE_ME

# ─────────────────────────────────────────────
# Backend (Railway) — set in Railway dashboard
# ─────────────────────────────────────────────
# ANTHROPIC_API_KEY=sk-ant-REPLACE_ME
# STRIPE_SECRET_KEY=sk_live_REPLACE_ME
# SUPABASE_SERVICE_ROLE_KEY=REPLACE_ME
