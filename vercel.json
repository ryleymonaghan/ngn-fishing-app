{
  "buildCommand": "npx expo export --platform web",
  "outputDirectory": "dist",
  "framework": null,
  "functions": {
    "api/**/*.js": { "runtime": "@vercel/node@3" }
  },
  "redirects": [
    { "source": "/", "destination": "/login", "permanent": false }
  ],
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/:path*" },
    { "source": "/login", "destination": "/login.html" },
    { "source": "/tabs", "destination": "/tabs.html" },
    { "source": "/tabs/reports", "destination": "/tabs/reports.html" },
    { "source": "/tabs/spots", "destination": "/tabs/spots.html" },
    { "source": "/tabs/catches", "destination": "/tabs/catches.html" },
    { "source": "/tabs/triplog", "destination": "/tabs/triplog.html" },
    { "source": "/tabs/profile", "destination": "/tabs/profile.html" },
    { "source": "/wizard/step1", "destination": "/wizard/step1.html" },
    { "source": "/wizard/step2", "destination": "/wizard/step2.html" },
    { "source": "/wizard/step3", "destination": "/wizard/step3.html" },
    { "source": "/report/:id", "destination": "/report/[id].html" }
  ]
}
